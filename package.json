{
  "name": "@sachitv/opencode-kilo-code-provider",
  "version": "0.1.0",
  "description": "OpenCode provider plugin for the Kilo Code Gateway with dynamic model discovery.",
  "type": "module",
  "license": "MIT",
  "author": "Sachit Vithaldas",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./provider": "./dist/provider.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts src/provider.ts --outdir dist --target bun --format esm --external @ai-sdk/openai-compatible",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.51"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.8",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sachitv/opencode-kilo-code-provider.git"
  },
  "bugs": {
    "url": "https://github.com/sachitv/opencode-kilo-code-provider/issues"
  },
  "homepage": "https://github.com/sachitv/opencode-kilo-code-provider#readme",
  "keywords": [
    "opencode",
    "kilo",
    "kilo-code",
    "ai-sdk",
    "provider",
    "gateway",
    "plugin"
  ]
}
